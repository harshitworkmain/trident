# Development Environment Configuration
FLASK_ENV=development
FLASK_DEBUG=True
FLASK_APP=src.backend.main

# Database
DATABASE_URL=sqlite:///data/databases/trident_sos.db

# Security
SECRET_KEY=dev-secret-key-change-in-production

# API Settings
API_HOST=0.0.0.0
API_PORT=5000

# ML Models
WEATHER_MODEL_PATH=data/models/weather_lstm.pth
MODEL_UPDATE_INTERVAL=3600

# ROV Configuration
ROV_SERIAL_PORT=/dev/ttyUSB0
ROV_BAUD_RATE=115200
ROV_TIMEOUT=30

# Logging
LOG_LEVEL=DEBUG
LOG_FILE=logs/trident_dev.log

# External Services
WEATHER_API_KEY=your-weather-api-key
GPS_API_KEY=your-gps-api-key

# Emergency Contacts
EMERGENCY_PHONE=100
FIRE_DEPARTMENT=101
MEDICAL_EMERGENCY=108