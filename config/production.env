# Production Environment Configuration
FLASK_ENV=production
FLASK_DEBUG=False
FLASK_APP=src.backend.main

# Database
DATABASE_URL=sqlite:///data/databases/trident_sos.db

# Security
SECRET_KEY=CHANGE_THIS_IN_PRODUCTION_SECURE_KEY

# API Settings
API_HOST=0.0.0.0
API_PORT=5000

# ML Models
WEATHER_MODEL_PATH=data/models/weather_lstm.pth
MODEL_UPDATE_INTERVAL=3600

# ROV Configuration
ROV_SERIAL_PORT=/dev/ttyUSB0
ROV_BAUD_RATE=115200
ROV_TIMEOUT=30

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/trident_prod.log

# External Services
WEATHER_API_KEY=your-production-weather-api-key
GPS_API_KEY=your-production-gps-api-key

# Emergency Contacts
EMERGENCY_PHONE=100
FIRE_DEPARTMENT=101
MEDICAL_EMERGENCY=108