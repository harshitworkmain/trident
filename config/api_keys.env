# API Keys Configuration Template
# Copy this file to api_keys.env and fill in your actual API keys

# Weather API Services
OPENWEATHER_API_KEY=your-openweather-api-key
WEATHERAPI_KEY=your-weatherapi-key

# Mapping and Location Services
GOOGLE_MAPS_API_KEY=your-google-maps-api-key
MAPBOX_API_KEY=your-mapbox-api-key

# Communication Services
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=your-twilio-phone-number

# Database Services (if using cloud databases)
FIREBASE_CONFIG=your-firebase-config
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key

# Monitoring and Analytics
SENTRY_DSN=your-sentry-dsn
GOOGLE_ANALYTICS_ID=your-google-analytics-id

# Emergency Service APIs
EMERGENCY_SERVICE_API_KEY=your-emergency-service-api-key
DISASTER_ALERT_API_KEY=your-disaster-alert-api-key